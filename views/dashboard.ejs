<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen p-3 sm:p-4 md:p-10">
    <div class="max-w-5xl mx-auto bg-white rounded-2xl shadow-xl ring-1 ring-slate-200 overflow-hidden">
        <div class="h-1.5 bg-indigo-700"></div>
        <div class="p-4 sm:p-6 md:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6 md:mb-8">
                <div>
                    <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">Receipt Generator</h1>
                    <p class="text-sm text-slate-500 mt-1">Create ACH and SWIFT receipts</p>
                </div>
                <div class="sm:text-right">
                    <p class="text-sm text-slate-500">Signed in as</p>
                    <p class="text-sm font-semibold text-slate-800"><%= username %></p>
                    <form method="POST" action="/logout" class="mt-2">
                        <button class="text-xs text-slate-600 hover:text-slate-900 underline" type="submit">Log out</button>
                    </form>
                </div>
            </div>

            <form action="/generate-receipt" method="POST" class="space-y-4 md:space-y-5">
                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="paymentType">Payment Type</label>
                        <select id="paymentType" name="paymentType" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            <option value="ach">ACH (USD)</option>
                            <option value="swift_usd">SWIFT (USD)</option>
                            <option value="swift_euro">SWIFT (EUR)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="amount">Amount</label>
                        <input type="text" id="amount" name="amount" required class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="700.00">
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="transactionType">Transaction Type</label>
                        <input type="text" id="transactionType" name="transactionType" value="Transfer" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="referenceNumber">Reference Number</label>
                        <input type="text" id="referenceNumber" name="referenceNumber" required class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="b59943c...">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="recipientName">Recipient Name</label>
                        <input type="text" id="recipientName" name="recipientName" required class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="senderName">Sender Name</label>
                        <input type="text" id="senderName" name="senderName" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="transferNote">Transfer Note</label>
                        <input type="text" id="transferNote" name="transferNote" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="transactionDateTime">Transaction Date & Time</label>
                        <input type="datetime-local" id="transactionDateTime" name="transactionDateTime" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                </div>

                <div id="form-details" class="grid md:grid-cols-2 gap-4"></div>

                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1" for="status">Status</label>
                        <select id="status" name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            <option value="">Select status (optional)</option>
                            <option value="Settled">Settled</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>
                </div>

                <button type="submit" class="w-full sm:w-auto rounded-lg bg-slate-900 text-white px-5 py-2.5 font-medium hover:bg-slate-800 transition">Generate Receipt</button>
            </form>
        </div>
    </div>

    <div id="form-data-holder" style="display: none;"><% if (typeof formData !== 'undefined' && formData) { %><%= JSON.stringify(formData) %><% } %></div>

    <script>
        const paymentTypeSelect = document.getElementById('paymentType');
        const formDetails = document.getElementById('form-details');
        const formDataHolder = document.getElementById('form-data-holder');
        let savedFormData = null;
        
        try {
            const rawData = formDataHolder.textContent.trim();
            if (rawData) {
                savedFormData = JSON.parse(rawData);
            }
        } catch (e) {
            console.log('No saved form data');
        }

        const forms = {
            ach: `
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="paymentMethod">Payment Method</label>
                    <input type="text" id="paymentMethod" name="paymentMethod" value="ACH/RTP" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="bankName">Bank Name</label>
                    <input type="text" id="bankName" name="bankName" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="accountNumber">Account Number</label>
                    <input type="text" id="accountNumber" name="accountNumber" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="routingNumber">Routing Number</label>
                    <input type="text" id="routingNumber" name="routingNumber" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
            `,
            swift_usd: `
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="paymentMethod">Payment Method</label>
                    <input type="text" id="paymentMethod" name="paymentMethod" value="SWIFT" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="bankName">Bank Name</label>
                    <input type="text" id="bankName" name="bankName" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="accountNumber">Account Number</label>
                    <input type="text" id="accountNumber" name="accountNumber" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="iban">IBAN</label>
                    <input type="text" id="iban" name="iban" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="swiftCode">BIC / SWIFT</label>
                    <input type="text" id="swiftCode" name="bic" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
            `,
            swift_euro: `
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="paymentMethod">Payment Method</label>
                    <input type="text" id="paymentMethod" name="paymentMethod" value="SWIFT" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="iban">IBAN</label>
                    <input type="text" id="iban" name="iban" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="bic">BIC / SWIFT</label>
                    <input type="text" id="bic" name="bic" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1" for="country">Country</label>
                    <input type="text" id="country" name="country" class="w-full rounded-lg border border-slate-300 px-3 py-2">
                </div>
            `,
        };

        function updateForm() {
            // Clear the form details
            formDetails.innerHTML = '';
            
            // Get the selected payment type
            const selectedType = paymentTypeSelect.value;
            
            // Update the form with the correct fields
            if (forms[selectedType]) {
                formDetails.innerHTML = forms[selectedType];
            }
            
            // Apply saved form data to the newly created fields
            if (savedFormData) {
                // Get all input fields in the form details
                const inputs = formDetails.querySelectorAll('input');
                inputs.forEach(input => {
                    if (savedFormData[input.id]) {
                        input.value = savedFormData[input.id];
                    }
                });
            }
        }

        // Event listener for dropdown changes
        paymentTypeSelect.addEventListener('change', function() {
            // Clear saved data to prevent conflicts when user manually changes
            savedFormData = null;
            updateForm();
        });

        // Initialize the form
        function initializeForm() {
            // First, set the dropdown value from saved data if available
            if (savedFormData && savedFormData.paymentType) {
                paymentTypeSelect.value = savedFormData.paymentType;
            }
            
            // Update the form
            updateForm();
            
            // Populate common fields from saved data
            if (savedFormData) {
                const commonFields = ['amount', 'transactionType', 'referenceNumber', 'recipientName', 'senderName', 'transferNote', 'transactionDateTime', 'status'];
                commonFields.forEach(fieldId => {
                    const field = document.getElementById(fieldId);
                    if (field && savedFormData[fieldId]) {
                        field.value = savedFormData[fieldId];
                    }
                });
            }
            
            // Clear saved data after populating to prevent interference
            savedFormData = null;
        }

        initializeForm();
    </script>
</body>
</html>