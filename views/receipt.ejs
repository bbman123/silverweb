<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receipt</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen p-3 sm:p-4 md:p-10 text-slate-700">
    <div class="max-w-3xl mx-auto bg-white shadow-xl ring-1 ring-slate-200 rounded-2xl overflow-hidden">
        <div class="h-1.5 bg-indigo-700"></div>
        <div class="p-3 sm:p-6 md:p-8 text-xs sm:text-sm md:text-base">
            <p class="text-indigo-800 text-xs sm:text-sm font-semibold">Transaction Amount</p>
            <h1 class="mt-1 text-2xl sm:text-4xl font-bold text-slate-900 leading-tight">
                <%
                    const formattedAmount = new Intl.NumberFormat('en-US', {
                        style: 'decimal',
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }).format(amount);
                %>
                <% if (paymentType === 'swift_euro') { %>
                    EUR <%= formattedAmount %>
                <% } else { %>
                    USD <%= formattedAmount %>
                <% } %>
            </h1>

            <% 
                const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
                function formatDateTime(dt) {
                    const d = dt ? new Date(dt) : new Date();
                    const day = d.getDate();
                    const month = months[d.getMonth()];
                    const year = d.getFullYear();
                    let hours = d.getHours();
                    const minutes = String(d.getMinutes()).padStart(2, '0');
                    const ampm = hours >= 12 ? 'pm' : 'am';
                    hours = hours % 12 || 12;
                    return `${day} ${month} ${year} at ${hours}:${minutes} ${ampm}`;
                }
            %>

            <div class="mt-5 sm:mt-8 border border-slate-200 rounded-2xl overflow-hidden">
                <% const rowEntries = [
                    ['Transaction Type', details.transactionType || 'Transfer'],
                    ['Recipient Name', details.recipientName || '-'],
                    // Only include Sender Name if it exists in details
                    ...(details.senderName ? [['Sender Name', details.senderName]] : []),
                    ['Reference Number', details.referenceNumber || '-'],
                    ['Payment Method', details.paymentMethod || '-'],
                    ['Bank Name', details.bankName],
                    ['Account Number', details.accountNumber],
                    ['Routing Number', details.routingNumber],
                    ['IBAN', details.iban],
                    ['BIC', details.bic],
                    ['Country', details.country],
                    ['Transfer Note', details.transferNote],
                    ['Transaction Date & Time', formatDateTime(details.transactionDateTime)],
                ].filter((item) => item[1]); %>

                <% rowEntries.forEach(function(item) { %>
                    <div class="grid grid-cols-2 gap-2 sm:gap-4 px-3 sm:px-4 md:px-6 py-2.5 sm:py-4 border-b border-slate-200">
                        <p class="text-slate-700 font-medium"><%= item[0] %></p>
                        <p class="text-right text-slate-600 font-semibold break-all"><%= item[1] %></p>
                    </div>
                <% }) %>
                <% if (details.status) { %>
                    <div class="grid grid-cols-2 gap-2 sm:gap-4 px-3 sm:px-4 md:px-6 py-2.5 sm:py-4">
                        <p class="text-slate-700 font-medium">Status</p>
                        <p class="text-right">
                            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold <%= details.status === 'Settled' ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>">
                                <%= details.status %>
                            </span>
                        </p>
                    </div>
                <% } %>
            </div>

            <div class="mt-6 flex gap-3 justify-end print:hidden">
                <a href="/dashboard" class="rounded-lg border border-slate-300 px-4 py-2 text-slate-700 hover:bg-slate-50 text-center">Back</a>
                <button onclick="window.print()" class="rounded-lg bg-slate-900 text-white px-4 py-2 hover:bg-slate-800">Print</button>
            </div>
        </div>
    </div>
</body>
</html>