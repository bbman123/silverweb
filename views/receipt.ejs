<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receipt</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen p-4 md:p-10 text-slate-700">
    <div class="max-w-3xl mx-auto bg-white shadow-xl ring-1 ring-slate-200 rounded-2xl overflow-hidden">
        <div class="h-1.5 bg-indigo-700"></div>
        <div class="p-6 md:p-8">
            <p class="text-indigo-800 text-sm font-semibold">Transaction Amount</p>
            <h1 class="mt-1 text-4xl font-bold text-slate-900">
                <% if (paymentType === 'swift_euro') { %>
                    EUR <%= amount %>
                <% } else { %>
                    USD <%= amount %>
                <% } %>
            </h1>

            <div class="mt-8 border border-slate-200 rounded-2xl overflow-hidden">
                <% const rowEntries = [
                    ['Transaction Type', details.transactionType || 'Transfer'],
                    ['Recipient Name', details.recipientName || '-'],
                    ['Sender Name', details.senderName || '-'],
                    ['Transaction Reference', details.transactionReference || '-'],
                    ['Payment Method', details.paymentMethod || '-'],
                    ['Bank Name', details.bankName],
                    ['Account Number', details.accountNumber],
                    ['Routing Number', details.routingNumber],
                    ['IBAN', details.iban],
                    ['BIC', details.bic],
          