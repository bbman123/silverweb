<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receipt</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen p-4 md:p-10 text-slate-700">
    <div class="max-w-3xl mx-auto bg-white shadow-xl ring-1 ring-slate-200 rounded-2xl overflow-hidden">
        <div class="h-1.5 bg-indigo-700"></div>
        <div class="p-6 md:p-8">
            <p class="text-indigo-800 text-sm font-semibold">Transaction Amount</p>
            <h1 class="mt-1 text-4xl font-bold text-slate-900">
                <% if (paymentType === 'swift_euro') { %>
                    EUR <%= amount %>
                <% } else { %>
                    USD <%= amount %>
                <% } %>
            </h1>

            <div class="mt-8 border border-slate-200 rounded-2xl overflow-hidden">
                <% const rowEntries = [
                    ['Transaction Type', details.transactionType || 'Transfer'],
                    ['Recipient Name', details.recipientName || '-'],
                    ['Sender Name', details.senderName || '-'],
                    ['Reference Number', details.referenceNumber || '-'],
                    ['Payment Method', details.paymentMethod || '-'],
                    ['Bank Name', details.bankName],
                    ['Account Number', details.accountNumber],
                    ['Routing Number', details.routingNumber],
                    ['IBAN', details.iban],
                    ['BIC', details.bic],
                    ['Country', details.country],
                    ['Transfer Note', details.transferNote],
                    ['Transaction Date & Time', details.transactionDateTime || new Date().toLocaleString('en-GB', { dateStyle: 'medium', timeStyle: 'short' })],
                ].filter((item) => item[1]); %>

                <% rowEntries.forEach(function(item) { %>
                    <div class="grid grid-cols-2 gap-4 px-4 md:px-6 py-4 border-b border-slate-200 last:border-b-0">
                        <p class="text-slate-700 font-medium"><%= item[0] %></p>
                        <p class="text-right text-slate-600 font-semibold break-all"><%= item[1] %></p>
                    </div>
                <% }) %>
            </div>

            <div class="mt-6 flex gap-3 justify-end print:hidden">
                <a href="/dashboard" class="rounded-lg border border-slate-300 px-4 py-2 text-slate-700 hover:bg-slate-50">Back</a>
                <button onclick="window.print()" class="rounded-lg bg-slate-900 text-white px-4 py-2 hover:bg-slate-800">Print</button>
            </div>
        </div>
    </div>
</body>
</html>